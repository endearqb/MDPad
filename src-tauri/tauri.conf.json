{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDPad",
  "version": "0.1.0",
  "identifier": "com.mdpad.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MDPad",
        "width": 1180,
        "height": 780,
        "resizable": true,
        "decorations": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown document",
        "description": "Markdown file",
        "role": "Editor"
      }
    ]
  }
}
