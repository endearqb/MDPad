{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDPad",
  "version": "0.2.8",
  "identifier": "com.mdpad.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:tauri-assets",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MDPad",
        "width": 960,
        "height": 780,
        "minWidth": 420,
        "minHeight": 320,
        "resizable": true,
        "decorations": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": {
      "resources/samples": "samples",
      "resources/node-runtime": "node-runtime",
      "resources/marknative-renderer": "marknative-renderer",
      "resources/playwright-pdf": "playwright-pdf",
      "resources/export-doc-builder": "export-doc-builder",
      "resources/cli/mdpad-cli.exe": "cli/mdpad-cli.exe",
      "windows/add-user-path.ps1": "installer-scripts/add-user-path.ps1",
      "windows/remove-user-path.ps1": "installer-scripts/remove-user-path.ps1"
    },
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis-hooks.nsh",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown document",
        "description": "Markdown file",
        "role": "Editor"
      },
      {
        "ext": [
          "html",
          "htm"
        ],
        "name": "HTML document",
        "description": "HTML file",
        "role": "Editor"
      },
      {
        "ext": [
          "py",
          "js",
          "ts"
        ],
        "name": "Script source",
        "description": "Script source file",
        "role": "Editor"
      },
      {
        "ext": [
          "json"
        ],
        "name": "JSON document",
        "description": "JSON file",
        "role": "Editor"
      }
    ]
  }
}
