{
  "name": "mdpad",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "tauri:dev": "tauri dev",
    "version:sync": "node scripts/version-manager.mjs sync",
    "version:bump:patch": "node scripts/version-manager.mjs bump patch",
    "version:bump:minor": "node scripts/version-manager.mjs bump minor",
    "version:bump:major": "node scripts/version-manager.mjs bump major",
    "release:patch": "pnpm version:bump:patch && tauri build",
    "release:minor": "pnpm version:bump:minor && tauri build",
    "release:major": "pnpm version:bump:major && tauri build",
    "release:no-bump": "pnpm version:sync && tauri build",
    "tauri:build:no-bump": "pnpm release:no-bump",
    "tauri:build": "pnpm release:patch"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "@tiptap/extension-floating-menu": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-of-contents": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "baseui": "^14.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.575.0",
    "marked": "^15.0.7",
    "mermaid": "^11.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styletron-engine-atomic": "^1.6.2",
    "styletron-react": "^6.1.1",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "2.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild"
    ]
  }
}
